# Host ports (mapped to the containers' internal ports).
# Defaults if unset: API_PORT=5000, DB_PORT=3306.
API_PORT=5000   # http://localhost:${API_PORT} -> API
DB_PORT=3306    # localhost:${DB_PORT} -> MySQL (for DBeaver, etc.)

# Database connection (DB_HOST must be the compose service name for container-to-container traffic)
DB_HOST=db
DB_USER=changeme
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme
